DESIGN CODE
///////////////////////////////////////////////////////////////////////////
// AHB-LITE PROTOCOL DESIGN 
///////////////////////////////////////////////////////////////////////////
// MODULE 1 : Package
///////////////////////////////////////////////////////////////////////////

package definesPkg;

    /**************** SLAVE ****************/
    parameter   ADDRESS_DEPTH           = 1024;
    parameter   READ_ONLY_START_ADDRESS = 32'h00000000;
    parameter   READ_ONLY_END_ADDRESS   = 32'h00000003;
    parameter   WAIT_ADDRESS            = 32'h00000005;

    /**************** INTERFACE ****************/
    parameter   ADDRESS_WIDTH  = 32;
    parameter   DATA_WIDTH     = 32;
    parameter   HSIZE_WIDTH    = 3;
    parameter   BURST_SIZE     = 3;
    parameter   TRANSFER_TYPE  = 2;

    // HTRANS encoding
    parameter   IDLE    = 2'b00;
    parameter   BUSY    = 2'b01;
    parameter   NON_SEQ = 2'b10;
    parameter   SEQ     = 2'b11;

endpackage


///////////////////////////////////////////////////////////////////////////
// MODULE 2 : Interface
///////////////////////////////////////////////////////////////////////////

import definesPkg::*;

interface AHBInterface (input logic HCLK, input logic HRESETn);

    import definesPkg::*;

    //////////////////////////////////////////////// SIGNALS ///////////////

    logic [ADDRESS_WIDTH-1:0]   HADDR;
    logic                       HWRITE;
    logic [HSIZE_WIDTH-1:0]     HSIZE;
    logic [BURST_SIZE-1:0]      HBURST;
    logic [TRANSFER_TYPE-1:0]   HTRANS;
    logic [DATA_WIDTH-1:0]      HWDATA;
    logic [DATA_WIDTH-1:0]      HRDATA;
    logic                       HREADY;
    logic                       HRESP;

    //////////////////////////////////////////////// TASKS /////////////////

 
    task read(input  bit   [ADDRESS_WIDTH-1:0] addr,
              output logic [DATA_WIDTH-1:0]    data);
        // Address phase
        @(posedge HCLK);
        HADDR  <= addr;
        HWRITE <= 1'b0;
        HSIZE  <= 3'b010;
        HBURST <= 3'b000;
        HTRANS <= NON_SEQ;          // FIX BUG-3: was missing

        // Pipeline: one clock for address phase to settle
        @(posedge HCLK);
        HTRANS <= IDLE;             // de-assert after address phase

        // Data phase: wait for slave to be ready
        @(posedge HCLK);            // FIX BUG-4: explicit wait for data phase
        while (!HREADY) @(posedge HCLK);
        data = HRDATA;

        if (HRESP) $display("[READ  TASK] ERROR RESPONSE from slave at addr=0x%08h", addr);
    endtask



    task burst_read(input  bit   [ADDRESS_WIDTH-1:0] addr,
                    input  int                        BEATS,
                    input  int                        busy,
                    output logic [DATA_WIDTH-1:0]     data_burst[31:0]);  // FIX BUG-10
        automatic int i = 0;
        automatic int j = 0;

        // Address phase — first beat NON_SEQ
        @(posedge HCLK);
        HADDR  <= addr;
        HTRANS <= NON_SEQ;
        HWRITE <= 1'b0;
        HSIZE  <= 3'b010;
        HBURST <= (BEATS == 4)  ? 3'b011 :
                  (BEATS == 8)  ? 3'b101 :
                  (BEATS == 16) ? 3'b111 : 3'b001; // INCR if unknown

        // Second address / BUSY insertion
        @(posedge HCLK);
        `ifndef ERROR_INJECT
            HADDR <= addr + 1;
        `endif

        // Insert BUSY cycles before continuing
        repeat(busy) begin
            j++;
            HTRANS <= BUSY;
            @(posedge HCLK);
            if (j == busy) HTRANS <= SEQ;
        end
        if (busy == 0) HTRANS <= SEQ;

        // Middle beats
        i = 0;
        repeat(BEATS - 2) begin
            @(posedge HCLK);
            HADDR       <= HADDR + 1;
            `ifndef ERROR_INJECT
                HTRANS  <= SEQ;
            `endif
            while (!HREADY) @(posedge HCLK);
            data_burst[i] = HRDATA;
            i = i + 1;
        end

        // Last two data beats (pipelined)
        @(posedge HCLK);
        HTRANS <= IDLE;
        while (!HREADY) @(posedge HCLK);
        data_burst[i] = HRDATA;
        i = i + 1;

        @(posedge HCLK);
        while (!HREADY) @(posedge HCLK);
        data_burst[i] = HRDATA;
    endtask



    task write(input bit   [ADDRESS_WIDTH-1:0] addr,
               input logic [DATA_WIDTH-1:0]    data);
        // Address phase
        @(posedge HCLK);
        HADDR  <= addr;
        HWRITE <= 1'b1;
        HSIZE  <= 3'b010;
        HBURST <= 3'b000;
        HTRANS <= NON_SEQ;          
        while (!HREADY) @(posedge HCLK);

        // Data phase
        @(posedge HCLK);
        `ifndef ERROR_INJECT
            HWDATA <= data;
        `endif
        HTRANS <= IDLE;             
        HWRITE <= 1'b0;

        @(posedge HCLK);
        if (HRESP)
            $display("[WRITE TASK] ERROR — write to read-only address 0x%08h", addr);
    endtask


    // -----------------------------------------------------------------------

    // -----------------------------------------------------------------------
    task burst_write(input bit   [ADDRESS_WIDTH-1:0] addr,
                     input int                        BEATS,
                     input int                        busy,
                     input logic [DATA_WIDTH-1:0]     data_arr[31:0]);

        automatic int ai = 0;   // address-phase beat counter  (FIX BUG-8)
        automatic int di = 0;   // data-phase beat counter
        automatic int bi = 0;   // busy-beat counter
        automatic bit [ADDRESS_WIDTH-1:0] cur_addr = addr;

        if      (BEATS == 4)  HBURST <= 3'b011;
        else if (BEATS == 8)  HBURST <= 3'b101;
        else if (BEATS == 16) HBURST <= 3'b111;
        else                  HBURST <= 3'b001;  // INCR

        if (HRESP) $display("[BURST_WRITE] Unexpected HRESP at start");

        fork
            // ------ Address phase thread ------
            begin : addr_thread
                repeat(BEATS) begin
                    @(posedge HCLK);
                    while (!HREADY) @(posedge HCLK);

                    HADDR  <= cur_addr;              
                    `ifndef ERROR_INJECT
                        HWRITE <= 1'b1;
                    `endif

                    if (ai == 0)
                        HTRANS <= NON_SEQ;
                    else
                        HTRANS <= SEQ;               

                    cur_addr = cur_addr + 4;
                    ai = ai + 1;

                    // BUSY insertion after beat 1 
                    if (busy >= 1 && ai == 2) begin
                        HTRANS <= BUSY;
                        @(posedge HCLK);
                    end
                    if (busy >= 2 && ai == 3) begin
                        HTRANS <= BUSY;
                        @(posedge HCLK);
                        @(posedge HCLK);
                    end
                end
                HTRANS <= IDLE;
                HWRITE <= 1'b0;
            end

            // ------ Data phase thread ------
            begin : data_thread
                @(posedge HCLK);  // pipeline offset: data is one cycle behind address
                repeat(BEATS) begin
                    while (!HREADY) @(posedge HCLK);
                    HWDATA <= data_arr[di];
                    di = di + 1;
                    bi = bi + 1;

                    // Match BUSY stalls in address thread
                    if (busy >= 1 && bi == 2) @(posedge HCLK);
                    if (busy >= 2 && bi == 3) begin
                        @(posedge HCLK);
                        @(posedge HCLK);
                    end

                    if (di < BEATS) @(posedge HCLK);
                end
            end
        join
    endtask


    //////////////////////////////////////////////// MODPORTS //////////////

    modport Slave (
        output  HREADY,
        output  HRESP,
        output  HRDATA,
        input   HADDR,
        input   HWRITE,
        input   HSIZE,
        input   HBURST,
        input   HTRANS,
        input   HWDATA,
        input   HCLK,
        input   HRESETn
    );

    modport Master (
        output  HADDR,
        output  HWRITE,
        output  HSIZE,
        output  HBURST,
        output  HTRANS,
        output  HWDATA,
        input   HRDATA,
        input   HREADY,
        input   HRESP,
        input   HCLK,
        input   HRESETn
    );

endinterface


///////////////////////////////////////////////////////////////////////////
// MODULE 3 : AHB Slave Memory (Core Slave RTL)
///////////////////////////////////////////////////////////////////////////

module AHBSlaveMemory (
    input  logic        HCLK,
    input  logic        HRESETn,
    input  logic [9:0]  HADDR,
    input  logic [31:0] HWDATA,
    input  logic [1:0]  HTRANS,
    input  logic        HWRITE,
    input  logic        HSEL,
    input  logic        wait_slave_to_master,
    output logic [31:0] HRDATA,
    output logic        HRESP,
    output logic        HREADY
);

   
    parameter   ADDR_SPACE              = 10;
    parameter   READ_ONLY_START_ADDR    = 10'h000;
    parameter   READ_ONLY_END_ADDR      = 10'h003;

    logic [9:0]  addr_reg;  // registered address (pipeline stage)
    logic [31:0] MemoryArray [2**ADDR_SPACE-1:0];

    always_ff @(posedge HCLK or negedge HRESETn) begin
        if (!HRESETn) begin
            HREADY    <= 1'b1;
            HRESP     <= 1'b0;
            addr_reg  <= '0;
            HRDATA    <= '0;
            `ifdef ERROR_INJECT
                HRESP <= 1'b1;   
            `endif
        end
        else if (HSEL) begin
            // IDLE or BUSY — slave is transparent, no action
            if (HTRANS == 2'b00 || HTRANS == 2'b01) begin
                HREADY <= 1'b1;
                HRESP  <= 1'b0;
            end
            else begin
                // NON_SEQ or SEQ transfer
                if (wait_slave_to_master) begin
                    // Insert wait state — hold HREADY low
                    HREADY <= 1'b0;
                    HRESP  <= 1'b0;
                end
                else begin
                    if (HWRITE) begin
                        // ---- Write operation ----
                      
                        if (HADDR >= READ_ONLY_START_ADDR &&
                            HADDR <= READ_ONLY_END_ADDR) begin
                            // Write to read-only region → error response
                            HREADY <= 1'b1;
                            `ifndef ERROR_INJECT
                                HRESP <= 1'b1;
                            `else
                                HRESP <= 1'b0;   // ERROR INJECTION suppresses error
                            `endif
                        end
                        else begin
                            MemoryArray[HADDR] <= HWDATA;
                            addr_reg           <= HADDR;
                            `ifndef ERROR_INJECT
                                HREADY <= 1'b1;
                            `else
                                HREADY <= 1'b0;  // ERROR INJECTION holds HREADY low
                            `endif
                            HRESP <= 1'b0;
                        end
                    end
                    else begin
                       
                        addr_reg <= HADDR;
                        HRDATA   <= MemoryArray[HADDR];  // use HADDR directly for 1-cycle read
                        HREADY   <= 1'b1;
                        HRESP    <= 1'b0;
                    end
                end
            end
        end
        else begin
            // Slave not selected — default ready, no error
            HREADY <= 1'b1;
            HRESP  <= 1'b0;
        end
    end

endmodule


///////////////////////////////////////////////////////////////////////////
// MODULE 4 : Address Decoder
///////////////////////////////////////////////////////////////////////////

`define NoOfSlaves 2

module decoder (
  
    input  logic [$clog2(`NoOfSlaves)-1:0]  Decode_address,
    output logic [`NoOfSlaves-1:0]           HSEL
);
    assign HSEL = (`NoOfSlaves'b1) << Decode_address;
endmodule


///////////////////////////////////////////////////////////////////////////
// MODULE 5 : AHB Slave Top (Wrapper + Decoder + Multi-slave)
///////////////////////////////////////////////////////////////////////////

parameter AddrBusWidth = 32;
parameter AddrSpace    = 10;

module AHBSlaveTop (
    AHBInterface        SlaveInterface,
    input logic         wait_slave_to_master
);

    logic [`NoOfSlaves-1:0]         HSEL;
    logic [`NoOfSlaves-1:0][31:0]   HRDATA_BUS;
    logic [`NoOfSlaves-1:0]         HRESP_BUS;
    logic [`NoOfSlaves-1:0]         HREADY_BUS;

    logic [$clog2(`NoOfSlaves)-1:0] decode_address;

    assign decode_address =
        SlaveInterface.HADDR[AddrSpace + $clog2(`NoOfSlaves) - 1 : AddrSpace];

    // Decoder instance
    decoder AHB_DEC (
        .Decode_address (decode_address),
        .HSEL           (HSEL)
    );

    // Generate multiple slave instances
    genvar i;
    generate
        for (i = 0; i < `NoOfSlaves; i++) begin : slave_gen
            AHBSlaveMemory AHBMemi (
                .HCLK                 (SlaveInterface.HCLK),
                .HRESETn              (SlaveInterface.HRESETn),
                .HADDR                (SlaveInterface.HADDR[AddrSpace-1:0]),
                .HWDATA               (SlaveInterface.HWDATA),
                .HTRANS               (SlaveInterface.HTRANS),
                .HWRITE               (SlaveInterface.HWRITE),
                .HSEL                 (HSEL[i]),
                .wait_slave_to_master (wait_slave_to_master),
                .HRDATA               (HRDATA_BUS[i]),
                .HRESP                (HRESP_BUS[i]),
                .HREADY               (HREADY_BUS[i])
            );
        end
    endgenerate

 
    always_comb begin
        // Default: select from the addressed slave
        SlaveInterface.HRDATA = HRDATA_BUS[decode_address];
        SlaveInterface.HRESP  = HRESP_BUS[decode_address];
        SlaveInterface.HREADY = HREADY_BUS[decode_address];

        // Out-of-range address: override with default slave error response
        if (SlaveInterface.HADDR >= (`NoOfSlaves * (2 ** AddrSpace))) begin
            if (SlaveInterface.HTRANS == 2'b10 ||
                SlaveInterface.HTRANS == 2'b11) begin
                SlaveInterface.HRESP  = 1'b1;
                SlaveInterface.HREADY = 1'b0;
            end
            else begin
                SlaveInterface.HRESP  = 1'b0;
                SlaveInterface.HREADY = 1'b1;
            end
            SlaveInterface.HRDATA = 32'hDEAD_BEEF;  
        end
    end

endmodule


///////////////////////////////////////////////////////////////////////////
// MODULE 6 : AHB Master (Synthesizable RTL)
///////////////////////////////////////////////////////////////////////////

module AHBMaster (
    input  logic                        HCLK,
    input  logic                        HRESETn,

    // Control inputs from testbench
    input  logic                        transfer_req,
    input  logic                        write_en,
    input  logic [31:0]                 addr_in,
    input  logic [31:0]                 wdata_in,
    input  logic [2:0]                  hsize_in,
    input  logic                        burst_en,
    input  logic [2:0]                  burst_type_in,
    input  logic [4:0]                  burst_beats_in,

    // Status outputs to testbench
    output logic [31:0]                 rdata_out,
    output logic                        transfer_done,
    output logic                        master_busy,
    output logic                        error_flag,

    // AHB-Lite bus
    AHBInterface.Master                 MasterInterface
);

    import definesPkg::*;

    // -------------------------------------------------------------------
    // State Machine
    // -------------------------------------------------------------------
    typedef enum logic [2:0] {
        ST_IDLE        = 3'b000,
        ST_SINGLE_ADDR = 3'b001,
        ST_SINGLE_DATA = 3'b010,
        ST_BURST_ADDR  = 3'b011,
        ST_BURST_DATA  = 3'b100,
        ST_BURST_LAST  = 3'b101,
        ST_ERROR       = 3'b110
    } state_t;

    state_t current_state, next_state;

    // Internal registers
    logic [31:0] haddr_reg;
    logic [31:0] hwdata_reg;
    logic        hwrite_reg;
    logic [2:0]  hsize_reg;
    logic [2:0]  hburst_reg;
    logic [4:0]  beat_count;
    logic [31:0] last_hwdata_reg;   

    // State register
    always_ff @(posedge HCLK or negedge HRESETn) begin
        if (!HRESETn) current_state <= ST_IDLE;
        else          current_state <= next_state;
    end

    // Next state logic
    always_comb begin
        next_state = current_state;
        case (current_state)
            ST_IDLE:
                if (transfer_req)
                    next_state = burst_en ? ST_BURST_ADDR : ST_SINGLE_ADDR;

            ST_SINGLE_ADDR:
                next_state = ST_SINGLE_DATA;

            ST_SINGLE_DATA: begin
                if (MasterInterface.HRESP)
                    next_state = ST_ERROR;
                else if (MasterInterface.HREADY)
                    next_state = ST_IDLE;
            end

            ST_BURST_ADDR:
                next_state = ST_BURST_DATA;

            ST_BURST_DATA: begin
                if (MasterInterface.HRESP)
                    next_state = ST_ERROR;
                else if (MasterInterface.HREADY && beat_count == 5'd1)
                    next_state = ST_BURST_LAST;
            end

            ST_BURST_LAST: begin
                if (MasterInterface.HRESP)
                    next_state = ST_ERROR;
                else if (MasterInterface.HREADY)
                    next_state = ST_IDLE;
            end

            ST_ERROR:
                next_state = ST_IDLE;

            default:
                next_state = ST_IDLE;
        endcase
    end

    // Output / datapath logic
    always_ff @(posedge HCLK or negedge HRESETn) begin
        if (!HRESETn) begin
            haddr_reg                  <= '0;
            hwdata_reg                 <= '0;
            last_hwdata_reg            <= '0;
            hwrite_reg                 <= 1'b0;
            hsize_reg                  <= 3'b010;
            hburst_reg                 <= 3'b000;
            beat_count                 <= 5'd0;
            rdata_out                  <= '0;
            transfer_done              <= 1'b0;
            error_flag                 <= 1'b0;
            MasterInterface.HADDR      <= '0;
            MasterInterface.HWRITE     <= 1'b0;
            MasterInterface.HSIZE      <= 3'b010;
            MasterInterface.HBURST     <= 3'b000;
            MasterInterface.HTRANS     <= IDLE;
            MasterInterface.HWDATA     <= '0;
        end
        else begin
            transfer_done <= 1'b0;
            error_flag    <= 1'b0;

            case (current_state)

                ST_IDLE: begin
                    MasterInterface.HTRANS <= IDLE;
                    MasterInterface.HADDR  <= '0;
                    MasterInterface.HWRITE <= 1'b0;
                    if (transfer_req) begin
                        haddr_reg       <= addr_in;
                        hwrite_reg      <= write_en;
                        hsize_reg       <= hsize_in;
                        hwdata_reg      <= wdata_in;
                        last_hwdata_reg <= wdata_in;  
                        if (burst_en) begin
                            hburst_reg <= burst_type_in;
                            beat_count <= burst_beats_in - 1;
                        end else begin
                            hburst_reg <= 3'b000;
                        end
                    end
                end

                ST_SINGLE_ADDR: begin
                    MasterInterface.HADDR  <= haddr_reg;
                    MasterInterface.HWRITE <= hwrite_reg;
                    MasterInterface.HSIZE  <= hsize_reg;
                    MasterInterface.HBURST <= 3'b000;
                    MasterInterface.HTRANS <= NON_SEQ;
                end

                ST_SINGLE_DATA: begin
                    if (hwrite_reg)
                        MasterInterface.HWDATA <= hwdata_reg;
                    if (MasterInterface.HREADY) begin
                        if (!hwrite_reg)
                            rdata_out <= MasterInterface.HRDATA;
                        if (!MasterInterface.HRESP) begin
                            transfer_done          <= 1'b1;
                            MasterInterface.HTRANS <= IDLE;
                        end
                    end
                    if (MasterInterface.HRESP) begin
                        error_flag             <= 1'b1;
                        MasterInterface.HTRANS <= IDLE;
                    end
                end

                ST_BURST_ADDR: begin
                    MasterInterface.HADDR  <= haddr_reg;
                    MasterInterface.HWRITE <= hwrite_reg;
                    MasterInterface.HSIZE  <= hsize_reg;
                    MasterInterface.HBURST <= hburst_reg;
                    MasterInterface.HTRANS <= NON_SEQ;
                end

                ST_BURST_DATA: begin
                    if (MasterInterface.HREADY) begin
                        if (!hwrite_reg)
                            rdata_out <= MasterInterface.HRDATA;
                        if (beat_count > 5'd1) begin
                            haddr_reg              <= haddr_reg + 4;
                            MasterInterface.HADDR  <= haddr_reg + 4;
                            MasterInterface.HTRANS <= SEQ;
                            last_hwdata_reg        <= hwdata_reg;  
                            hwdata_reg             <= wdata_in;
                            MasterInterface.HWDATA <= hwdata_reg;
                            beat_count             <= beat_count - 1;
                        end
                        else begin
                            
                            MasterInterface.HTRANS <= IDLE;
                            MasterInterface.HWDATA <= hwdata_reg;
                            beat_count             <= 5'd0;
                        end
                    end
                    if (MasterInterface.HRESP) begin
                        error_flag             <= 1'b1;
                        MasterInterface.HTRANS <= IDLE;
                    end
                end

                ST_BURST_LAST: begin
                    MasterInterface.HTRANS <= IDLE;
                    
                    if (hwrite_reg)
                        MasterInterface.HWDATA <= last_hwdata_reg;
                    if (MasterInterface.HREADY) begin
                        if (!hwrite_reg)
                            rdata_out <= MasterInterface.HRDATA;
                        if (!MasterInterface.HRESP)
                            transfer_done <= 1'b1;
                    end
                    if (MasterInterface.HRESP)
                        error_flag <= 1'b1;
                end

                ST_ERROR: begin
                    error_flag             <= 1'b1;
                    MasterInterface.HTRANS <= IDLE;
                    MasterInterface.HWRITE <= 1'b0;
                    MasterInterface.HADDR  <= '0;
                end

                default: MasterInterface.HTRANS <= IDLE;

            endcase
        end
    end

    assign master_busy = (current_state != ST_IDLE);

endmodule





