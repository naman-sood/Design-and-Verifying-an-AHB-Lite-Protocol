S1- SINGLE WRITE
`timescale 1ns/1ps

module tb_single_write;

    import definesPkg::*;

    // Clock & Reset
    logic HCLK;
    logic HRESETn;

    // Interface
    AHBInterface ahb_if (HCLK, HRESETn);

    // DUT
    logic wait_slave_to_master;

    AHBSlaveTop dut (
        .SlaveInterface(ahb_if),
        .wait_slave_to_master(wait_slave_to_master)
    );

    // ================================
    //  Waveform Dump (EPWave)
    // ================================
    initial begin
        $dumpfile("dump.vcd");
        $dumpvars(0, tb_single_write);
    end

    // Clock Generation
    initial begin
        HCLK = 0;
        forever #5 HCLK = ~HCLK;
    end

    // Reset Task
    task reset_dut();
        begin
            HRESETn = 0;
            wait_slave_to_master = 0;
            repeat(5) @(posedge HCLK);
            HRESETn = 1;
        end
    endtask
  initial begin
    ahb_if.HADDR  = 0;
    ahb_if.HWRITE = 0;
    ahb_if.HTRANS = IDLE;
    ahb_if.HSIZE  = 0;
    ahb_if.HBURST = 0;
    ahb_if.HWDATA = 0;
end

    // Test Variables
    logic [31:0] test_addr;
    logic [31:0] test_data;

    // ================================
    //  Test Sequence: S1 Single Write
    // ================================
    initial begin
        $display("\n===== S1: SINGLE WRITE TEST =====\n");

        reset_dut();

        test_addr = 32'h00000010;
        test_data = 32'hDEADBEEF;

        // Perform write
        ahb_if.write(test_addr, test_data);

        // Wait for pipeline completion
        repeat(3) @(posedge HCLK);

        // Check memory
        if (dut.slave_gen[0].AHBMemi.MemoryArray[test_addr[9:0]] == test_data) begin
            $display(" WRITE SUCCESS");
        end
        else begin
            $display(" WRITE FAILED");
        end

        $display("\n===== TEST END =====\n");
        $finish;
    end

endmodule

