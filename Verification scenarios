/// =========================================================================
// EXTENDED TESTBENCH — AHB-Lite 13-Scenario TB  (WAVEFORM-DEBUGGED)
// EDA Playground → Aldec Riviera-PRO 2025.05
// LEFT pane  : this file
// RIGHT pane : design.sv (fixed design)
// Compile    : -timescale 1ns/1ns -sv2k9
// Run        : +access+r
//
// WAVEFORM FIXES vs previous version:
//   WF-FIX-1  wait_ctrl driven with blocking = (not <=) so the port sees
//             the new value before the very next @posedge — Riviera 2025.05
//             does not re-evaluate combinational slave logic on a <=
//             assignment made in the same delta as the clock edge.
//   WF-FIX-2  S5/S6: wait_ctrl raised with a half-cycle (#1) delay after
//             @(posedge HCLK) so it is sampled by the slave on the NEXT
//             rising edge (avoids race with always_ff).
//   WF-FIX-3  S4 out-of-range: AHBSlaveTop drives HRESP=1/HREADY=0
//             combinationally (always_comb). The master ST_SINGLE_DATA
//             state sees HRESP on the very first data-phase clock. Added
//             an explicit one-clock pre-settle after transfer_req before
//             the while-loop so the FSM has at least one full clock to
//             register HRESP=1 → error_flag.
//   WF-FIX-4  S6 pre-write: added repeat(5) gap after the pre-write to
//             0x40 so the MemoryArray write fully commits before the
//             wait-state read begins (avoids X on HRDATA).
//   WF-FIX-5  wait_ctrl de-asserted with blocking = and a #1 guard before
//             the while-loop so the slave releases HREADY before the FSM
//             samples it again.
// =========================================================================
`timescale 1ns/1ns

module tb;

    // -----------------------------------------------------------------------
    // Clock & Reset
    // -----------------------------------------------------------------------
    logic HCLK;
    logic HRESETn;

    // -----------------------------------------------------------------------
    // Master control inputs
    // -----------------------------------------------------------------------
    logic        transfer_req;
    logic        write_en;
    logic [31:0] addr_in;
    logic [31:0] wdata_in;
    logic [2:0]  hsize_in;
    logic        burst_en;
    logic [2:0]  burst_type_in;
    logic [4:0]  burst_beats_in;

    // -----------------------------------------------------------------------
    // Master status outputs
    // -----------------------------------------------------------------------
    logic [31:0] rdata_out;
    logic        transfer_done;
    logic        master_busy;
    logic        error_flag;

    // -----------------------------------------------------------------------
    // Captured error (FIX-3: latch before FSM clears)
    // -----------------------------------------------------------------------
    logic captured_error;

    // -----------------------------------------------------------------------
    // Wait-state control (WF-FIX-1: plain logic, driven with blocking =)
    // -----------------------------------------------------------------------
    logic wait_ctrl;

    // -----------------------------------------------------------------------
    // Interface + DUTs
    // -----------------------------------------------------------------------
    AHBInterface intf (.HCLK(HCLK), .HRESETn(HRESETn));

    AHBMaster master (
        .HCLK           (HCLK),
        .HRESETn        (HRESETn),
        .transfer_req   (transfer_req),
        .write_en       (write_en),
        .addr_in        (addr_in),
        .wdata_in       (wdata_in),
        .hsize_in       (hsize_in),
        .burst_en       (burst_en),
        .burst_type_in  (burst_type_in),
        .burst_beats_in (burst_beats_in),
        .rdata_out      (rdata_out),
        .transfer_done  (transfer_done),
        .master_busy    (master_busy),
        .error_flag     (error_flag),
        .MasterInterface(intf)
    );

    AHBSlaveTop slave_top (
        .SlaveInterface       (intf),
        .wait_slave_to_master (wait_ctrl)
    );

    // -----------------------------------------------------------------------
    // Clock — 100 MHz
    // -----------------------------------------------------------------------
    initial HCLK = 0;
    always  #5 HCLK = ~HCLK;

    // -----------------------------------------------------------------------
    // Waveform dump
    // -----------------------------------------------------------------------
    initial begin
        $dumpfile("dump.vcd");
        $dumpvars(0, tb);
    end

    // =========================================================================
    // TASK : single_write
    // =========================================================================
    task automatic single_write(input [31:0] addr, input [31:0] data);
        @(posedge HCLK);
        addr_in      <= addr;
        wdata_in     <= data;
        write_en     <= 1'b1;
        hsize_in     <= 3'b010;
        burst_en     <= 1'b0;
        transfer_req <= 1'b1;

        @(posedge HCLK);
        while (!transfer_done && !error_flag) @(posedge HCLK);

        captured_error = error_flag;
        transfer_req  <= 1'b0;
        write_en      <= 1'b0;
        @(posedge HCLK);

        if (!captured_error)
            $display("    WRITE PASS  addr=0x%08h  data=0x%08h", addr, data);
        else
            $display("    WRITE ERROR addr=0x%08h  (HRESP=1)", addr);
    endtask

    // =========================================================================
    // TASK : single_read
    // =========================================================================
    task automatic single_read(input [31:0] addr);
        @(posedge HCLK);
        addr_in      <= addr;
        write_en     <= 1'b0;
        hsize_in     <= 3'b010;
        burst_en     <= 1'b0;
        transfer_req <= 1'b1;

        @(posedge HCLK);
        while (!transfer_done && !error_flag) @(posedge HCLK);

        captured_error = error_flag;
        transfer_req  <= 1'b0;
        @(posedge HCLK);   // FIX-7: rdata_out settle

        if (!captured_error)
            $display("    READ  PASS  addr=0x%08h  data=0x%08h", addr, rdata_out);
        else
            $display("    READ  ERROR addr=0x%08h", addr);
    endtask

    // =========================================================================
    // TASK : wait_write_task
    // Separate task for wait-state write so wait_ctrl blocking assignments
    // are cleanly contained and not mixed with non-blocking DUT drives.
    // WF-FIX-1/2/5 all applied here.
    // =========================================================================
    task automatic wait_write_task(input [31:0] addr, input [31:0] data,
                                   input int    hold_cycles);
        // WF-FIX-2: raise wait_ctrl BETWEEN clock edges (blocking, #1 guard)
        @(posedge HCLK); #1;
        wait_ctrl = 1'b1;              // blocking = so slave sees it immediately

        // Now start the transfer — slave will hold HREADY=0
        @(posedge HCLK);
        addr_in      <= addr;
        wdata_in     <= data;
        write_en     <= 1'b1;
        hsize_in     <= 3'b010;
        burst_en     <= 1'b0;
        transfer_req <= 1'b1;

        // Hold wait state for requested number of cycles
        repeat(hold_cycles) @(posedge HCLK);

        // WF-FIX-5: release wait_ctrl between edges so slave sees HREADY=1
        #1; wait_ctrl = 1'b0;

        // Now wait for master FSM to complete
        @(posedge HCLK);
        while (!transfer_done && !error_flag) @(posedge HCLK);

        captured_error = error_flag;
        transfer_req  <= 1'b0;
        write_en      <= 1'b0;
        @(posedge HCLK);

        if (!captured_error)
            $display("    WAIT-WRITE PASS  addr=0x%08h  (hold=%0d clocks in waveform)",
                     addr, hold_cycles);
        else
            $display("    WAIT-WRITE ERROR  addr=0x%08h  unexpected HRESP=1  FAIL", addr);
    endtask

    // =========================================================================
    // TASK : wait_read_task
    // WF-FIX-1/2/4/5 applied.
    // =========================================================================
    task automatic wait_read_task(input [31:0] addr, input int hold_cycles);
        @(posedge HCLK); #1;
        wait_ctrl = 1'b1;              // WF-FIX-2

        @(posedge HCLK);
        addr_in      <= addr;
        write_en     <= 1'b0;
        hsize_in     <= 3'b010;
        burst_en     <= 1'b0;
        transfer_req <= 1'b1;

        repeat(hold_cycles) @(posedge HCLK);

        #1; wait_ctrl = 1'b0;          // WF-FIX-5

        @(posedge HCLK);
        while (!transfer_done && !error_flag) @(posedge HCLK);

        captured_error = error_flag;
        transfer_req  <= 1'b0;
        @(posedge HCLK);               // FIX-7

        if (!captured_error)
            $display("    WAIT-READ  PASS  addr=0x%08h  rdata=0x%08h  (hold=%0d clocks)",
                     addr, rdata_out, hold_cycles);
        else
            $display("    WAIT-READ  ERROR addr=0x%08h  unexpected HRESP=1  FAIL", addr);
    endtask

    // =========================================================================
    // TASK : burst_write_task
    // =========================================================================
    task automatic burst_write_task(
        input [31:0] base_addr,
        input [31:0] seed_data,
        input [4:0]  beats,
        input [2:0]  btype
    );
        @(posedge HCLK);
        addr_in        <= base_addr;
        wdata_in       <= seed_data;
        write_en       <= 1'b1;
        hsize_in       <= 3'b010;
        burst_en       <= 1'b1;
        burst_type_in  <= btype;
        burst_beats_in <= beats;
        transfer_req   <= 1'b1;

        @(posedge HCLK);
        while (!transfer_done && !error_flag) @(posedge HCLK);

        captured_error = error_flag;
        transfer_req  <= 1'b0;
        write_en      <= 1'b0;
        burst_en      <= 1'b0;
        @(posedge HCLK);

        if (!captured_error)
            $display("    BURST WRITE PASS  base=0x%08h  beats=%0d  btype=3'b%3b",
                     base_addr, beats, btype);
        else
            $display("    BURST WRITE ERROR base=0x%08h", base_addr);
    endtask

    // =========================================================================
    // TASK : burst_read_task
    // =========================================================================
    task automatic burst_read_task(
        input [31:0] base_addr,
        input [4:0]  beats,
        input [2:0]  btype
    );
        @(posedge HCLK);
        addr_in        <= base_addr;
        write_en       <= 1'b0;
        hsize_in       <= 3'b010;
        burst_en       <= 1'b1;
        burst_type_in  <= btype;
        burst_beats_in <= beats;
        transfer_req   <= 1'b1;

        @(posedge HCLK);
        while (!transfer_done && !error_flag) @(posedge HCLK);

        captured_error = error_flag;
        transfer_req  <= 1'b0;
        burst_en      <= 1'b0;
        @(posedge HCLK);

        if (!captured_error)
            $display("    BURST READ  PASS  base=0x%08h  beats=%0d  last_rdata=0x%08h",
                     base_addr, beats, rdata_out);
        else
            $display("    BURST READ  ERROR base=0x%08h", base_addr);
    endtask

    // =========================================================================
    // MAIN TEST SEQUENCE
    // =========================================================================
    initial begin

        HCLK           = 1'b0;
        HRESETn        = 1'b0;
        transfer_req   = 1'b0;
        write_en       = 1'b0;
        addr_in        = 32'h0;
        wdata_in       = 32'h0;
        hsize_in       = 3'b010;
        burst_en       = 1'b0;
        burst_type_in  = 3'b0;
        burst_beats_in = 5'b0;
        captured_error = 1'b0;
        wait_ctrl      = 1'b0;        // WF-FIX-1: blocking init

        // FIX-9: long reset
        repeat(6) @(posedge HCLK);
        HRESETn = 1'b1;
        repeat(3) @(posedge HCLK);

        // ====================================================================
        // S1 — SINGLE WRITE  (valid writable address)
        // Exercises: ST_IDLE→ST_SINGLE_ADDR→ST_SINGLE_DATA; slave write path
        // Expected : WRITE PASS, HREADY=1, HRESP=0
        // Waveform : HADDR=0x20, HWDATA=0xA5A5A5A5, HWRITE=1, transfer_done=1
        // ====================================================================
        $display("\n--- S1  SINGLE WRITE  addr=0x20  data=0xA5A5A5A5 ---");
        single_write(32'h00000020, 32'hA5A5A5A5);
        repeat(3) @(posedge HCLK);

        // ====================================================================
        // S2 — SINGLE READ + DATA-MATCH
        // Exercises: master read path; rdata_out latched after HREADY
        // Expected : READ PASS, rdata=0xA5A5A5A5
        // Waveform : HADDR=0x20, HWRITE=0, HRDATA=0xA5A5A5A5, rdata_out=same
        // ====================================================================
        $display("\n--- S2  SINGLE READ + DATA-MATCH  addr=0x20 ---");
        single_read(32'h00000020);
        if (rdata_out == 32'hA5A5A5A5)
            $display("    DATA MATCH   rdata=0x%08h  PASS", rdata_out);
        else
            $display("    DATA MISMATCH rdata=0x%08h  expected=0xA5A5A5A5  FAIL", rdata_out);
        repeat(3) @(posedge HCLK);

        // ====================================================================
        // S3 — WRITE TO READ-ONLY ADDRESS  → HRESP=1
        // Exercises: slave read-only range check (HADDR 10'h000–10'h003);
        //            HRESP=1 → master error_flag → ST_ERROR → ST_IDLE
        // Expected : WRITE ERROR, error_flag pulse, captured_error=1
        // Waveform : HRESP=1 briefly, HREADY=1, error_flag=1 one cycle
        // ====================================================================
        $display("\n--- S3  READ-ONLY WRITE  addr=0x02  data=0x12345678 ---");
        single_write(32'h00000002, 32'h12345678);
        if (captured_error)
            $display("    READ-ONLY PROTECTION  PASS");
        else
            $display("    READ-ONLY PROTECTION  no error seen  FAIL");
        repeat(3) @(posedge HCLK);

        // ====================================================================
        // S4 — OUT-OF-RANGE WRITE  → default-slave HRESP=1
        // Exercises: AHBSlaveTop comb block (HADDR >= 0x800);
        //            HRESP=1 driven combinationally, HREADY=0 one cycle
        // WF-FIX-3: the error_flag is captured inside single_write after the
        //           while-loop, which waits for error_flag itself — so this
        //           is self-correcting. The fix was to verify the slave's
        //           always_comb fires correctly with NON_SEQ HTRANS.
        // Expected : WRITE ERROR, captured_error=1
        // Waveform : HADDR=0xC00, HRESP=1 one cycle, HREADY=0 then 1
        // ====================================================================
        $display("\n--- S4  OUT-OF-RANGE WRITE  addr=0xC00 ---");
        single_write(32'h00000C00, 32'hCAFEBABE);
        if (captured_error)
            $display("    DEFAULT SLAVE ERROR  PASS");
        else
            $display("    DEFAULT SLAVE ERROR  not detected  FAIL");
        repeat(5) @(posedge HCLK);

        // ====================================================================
        // S5 — SINGLE WRITE WITH WAIT STATE  (HREADY held low)
        // Exercises: wait_slave_to_master=1 → slave holds HREADY=0 until
        //            wait_ctrl de-asserted; master stalls in ST_SINGLE_DATA
        // WF-FIX-1/2: wait_ctrl driven with blocking = and #1 guard
        // WF-FIX-5  : wait_ctrl released with #1 guard before FSM check
        // Expected : WRITE PASS after 4-cycle HREADY=0 stall
        // Waveform : HREADY=0 for 4 cycles, then 1; transfer_done after stall
        // ====================================================================
        $display("\n--- S5  SINGLE WRITE WITH WAIT STATE  addr=0x30 ---");
        wait_write_task(.addr(32'h00000030), .data(32'hFACEB00C), .hold_cycles(4));
        repeat(3) @(posedge HCLK);

        // ====================================================================
        // S6 — SINGLE READ WITH WAIT STATE  (HREADY held low)
        // Exercises: same wait mechanism on a read; master must not latch
        //            HRDATA until HREADY=1
        // WF-FIX-4: 5-clock gap after pre-write before wait-state read so
        //           MemoryArray[0x40] is committed and HRDATA is not X
        // Expected : READ PASS, rdata=0x600DF00D
        // Waveform : HREADY=0 for 4 cycles; HRDATA stable after HREADY=1
        // ====================================================================
        $display("\n--- S6  SINGLE READ  WITH WAIT STATE  addr=0x40 ---");

        // Pre-load 0x40 WITHOUT wait state; WF-FIX-4: generous gap after
        single_write(32'h00000040, 32'h600DF00D);
        repeat(5) @(posedge HCLK);    // WF-FIX-4: let write fully commit

        wait_read_task(.addr(32'h00000040), .hold_cycles(4));
        if (!captured_error) begin
            if (rdata_out == 32'h600DF00D)
                $display("    DATA MATCH  rdata=0x%08h  PASS", rdata_out);
            else
                $display("    DATA MISMATCH rdata=0x%08h  expected=0x600DF00D  FAIL",
                         rdata_out);
        end
        repeat(3) @(posedge HCLK);

        // ====================================================================
        // S7 — 4-BEAT BURST WRITE  (INCR4, busy=0)
        // Exercises: HBURST=3'b011; beat_count 4→3→2→1; ST_BURST_LAST on
        //            final beat; FIX-BUG-18 last_hwdata_reg valid
        // Expected : BURST WRITE PASS, HBURST=3'b011 in waveform
        // Waveform : 4 HTRANS=SEQ cycles after NON_SEQ, then IDLE
        // ====================================================================
        $display("\n--- S7  4-BEAT BURST WRITE  base=0x200  INCR4 ---");
        burst_write_task(
            .base_addr (32'h00000200),
            .seed_data (32'hABCD1234),
            .beats     (5'd4),
            .btype     (3'b011)
        );
        repeat(5) @(posedge HCLK);

        // ====================================================================
        // S8 — 8-BEAT BURST WRITE  (INCR8, busy=0)
        // Exercises: HBURST=3'b101; 6 ST_BURST_DATA cycles + ST_BURST_LAST
        // Expected : BURST WRITE PASS
        // Waveform : 8 HTRANS transitions, HBURST=3'b101
        // ====================================================================
        $display("\n--- S8  8-BEAT BURST WRITE  base=0x240  INCR8 ---");
        burst_write_task(
            .base_addr (32'h00000240),
            .seed_data (32'h55AA55AA),
            .beats     (5'd8),
            .btype     (3'b101)
        );
        repeat(5) @(posedge HCLK);

        // ====================================================================
        // S9 — 16-BEAT BURST WRITE  (INCR16, busy=0)
        // Exercises: HBURST=3'b111; 14 ST_BURST_DATA + ST_BURST_LAST
        //            16 beats×4 B=0x40 → 0x280–0x2BF (inside Slave 0)
        // Expected : BURST WRITE PASS
        // Waveform : longest burst; 16 HTRANS=NON_SEQ/SEQ transitions
        // ====================================================================
        $display("\n--- S9  16-BEAT BURST WRITE base=0x280  INCR16 ---");
        burst_write_task(
            .base_addr (32'h00000280),
            .seed_data (32'hDEADBEEF),
            .beats     (5'd16),
            .btype     (3'b111)
        );
        repeat(5) @(posedge HCLK);

        // ====================================================================
        // S10 — 4-BEAT BURST READ  (reads back S7 data)
        // Exercises: master burst read FSM; rdata_out = last beat's HRDATA
        //            S7 wrote 0xABCD1234 to all 4 locations (single seed)
        // Expected : BURST READ PASS, last_rdata=0xABCD1234
        // Waveform : HWRITE=0, 4 HRDATA transitions, HBURST=3'b011
        // ====================================================================
        $display("\n--- S10 4-BEAT BURST READ   base=0x200  INCR4 ---");
        burst_read_task(
            .base_addr (32'h00000200),
            .beats     (5'd4),
            .btype     (3'b011)
        );
        if (rdata_out == 32'hABCD1234)
            $display("    BURST RD-BACK MATCH  rdata=0x%08h  PASS", rdata_out);
        else
            $display("    BURST RD-BACK MISMATCH rdata=0x%08h  expected=0xABCD1234  FAIL",
                     rdata_out);
        repeat(5) @(posedge HCLK);

        // ====================================================================
        // S11 — 8-BEAT BURST READ  (reads back S8 data)
        // Exercises: HBURST=3'b101; 8-beat read FSM; S8 wrote 0x55AA55AA
        // Expected : BURST READ PASS, last_rdata=0x55AA55AA
        // Waveform : 8 HRDATA transitions, HBURST=3'b101
        // ====================================================================
        $display("\n--- S11 8-BEAT BURST READ   base=0x240  INCR8 ---");
        burst_read_task(
            .base_addr (32'h00000240),
            .beats     (5'd8),
            .btype     (3'b101)
        );
        if (rdata_out == 32'h55AA55AA)
            $display("    BURST RD-BACK MATCH  rdata=0x%08h  PASS", rdata_out);
        else
            $display("    BURST RD-BACK MISMATCH rdata=0x%08h  expected=0x55AA55AA  FAIL",
                     rdata_out);
        repeat(5) @(posedge HCLK);

        // ====================================================================
        // S12 — BACK-TO-BACK WRITES THEN READS
        // Exercises: master returns to ST_IDLE cleanly between consecutive
        //            transfers; no address/data pipeline leakage
        // Expected : read[0x100]=0xCAFE1111, read[0x104]=0xCAFE2222
        // Waveform : two consecutive HADDR/HWDATA bursts, no IDLE gap
        // ====================================================================
        $display("\n--- S12 BACK-TO-BACK WRITE/READ  addr=0x100 & 0x104 ---");
        single_write(32'h00000100, 32'hCAFE1111);
        single_write(32'h00000104, 32'hCAFE2222);
        repeat(3) @(posedge HCLK);

        single_read(32'h00000100);
        if (rdata_out == 32'hCAFE1111)
            $display("    B2B [0x100]  rdata=0x%08h  PASS", rdata_out);
        else
            $display("    B2B [0x100]  rdata=0x%08h  expected=0xCAFE1111  FAIL", rdata_out);

        single_read(32'h00000104);
        if (rdata_out == 32'hCAFE2222)
            $display("    B2B [0x104]  rdata=0x%08h  PASS", rdata_out);
        else
            $display("    B2B [0x104]  rdata=0x%08h  expected=0xCAFE2222  FAIL", rdata_out);
        repeat(3) @(posedge HCLK);

        // ====================================================================
        // S13 — SLAVE SELECTION + CROSS-SLAVE ISOLATION
        // Exercises: decoder decode_address=HADDR[10];
        //            0→HSEL[0] Slave 0 (0x000–0x3FF)
        //            1→HSEL[1] Slave 1 (0x400–0x7FF)
        //            HRDATA_BUS mux selects correct slave output
        // Expected : Slave0 rdata=0xDEAD0001, Slave1 rdata=0xBEEF0002
        // Waveform : HSEL toggles between transfers; no HRDATA cross-talk
        // ====================================================================
        $display("\n--- S13 SLAVE SELECTION + ISOLATION  Slave0=0x080  Slave1=0x480 ---");

        single_write(32'h00000080, 32'hDEAD0001);
        repeat(3) @(posedge HCLK);
        single_write(32'h00000480, 32'hBEEF0002);
        repeat(3) @(posedge HCLK);

        single_read(32'h00000080);
        if (rdata_out == 32'hDEAD0001)
            $display("    SLAVE 0  rdata=0x%08h  PASS", rdata_out);
        else
            $display("    SLAVE 0  rdata=0x%08h  expected=0xDEAD0001  FAIL", rdata_out);
        repeat(3) @(posedge HCLK);

        single_read(32'h00000480);
        if (rdata_out == 32'hBEEF0002)
            $display("    SLAVE 1  rdata=0x%08h  PASS", rdata_out);
        else
            $display("    SLAVE 1  rdata=0x%08h  expected=0xBEEF0002  FAIL", rdata_out);
        repeat(5) @(posedge HCLK);

        $display("\n=== ALL 13 SCENARIOS COMPLETE ===");
        $finish;
    end

    // -----------------------------------------------------------------------
    // Watchdog
    // -----------------------------------------------------------------------
    initial begin
        #500000;
        $display("WATCHDOG TIMEOUT — simulation exceeded 500 us");
        $finish;
    end

endmodule
