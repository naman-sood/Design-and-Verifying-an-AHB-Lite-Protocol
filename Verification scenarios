S14-S20 CODE
// ============================================================
// UNIFIED AHB-LITE TESTBENCH — ALL 7 SCENARIOS
// Target  : Aldec Riviera-PRO 2025.04 / EDA Playground
// Left    : design.sv
// Right   : this file
// Compile : -timescale 1ns/1ns  -sv2k9
// Run     : +access+r
//
// FIXES vs previous versions
//   FIX-A  `timescale is a file-scope directive — placed ONCE at the
//           very top, never inside or between modules.
//   FIX-B  All 7 scenarios merged into ONE module (tb) with one DUT.
//           Riviera rejects multiple top-level modules in a single file
//           when they each declare the same DUT instance name.
//   FIX-C  NONSEQ renamed to NON_SEQ to match definesPkg parameter.
//   FIX-D  SINGLE renamed to 3'b000 (SINGLE is not in definesPkg).
//   FIX-E  settle() task added — repeat(3) @(posedge HCLK) — between
//           every write and read-back so MemoryArray pipeline commits.
//   FIX-F  T1 HRDATA sampling gated on HREADY=1.
//   FIX-G  T4 HRESP sampled ONE cycle before HTRANS returns to IDLE
//           so the always_comb OOR mux is still presenting the error.
//   FIX-H  T4 recovery uses unique address 0x50 (not 0x10) to avoid
//           reading stale data left by T2.
//   FIX-I  T7 error injection: write goes to read-only address 0x02
//           (not 0x10) so HRESP=1 fires from the slave's RO check.
// ============================================================
`timescale 1ns/1ns

module tb;

    import definesPkg::*;

    // --------------------------------------------------------
    // CLOCK + RESET
    // --------------------------------------------------------
    logic        HCLK;
    logic        HRESETn;
    logic        wait_ctrl;

    int          pass_count;
    int          fail_count;

    initial      HCLK = 1'b0;
    always  #5   HCLK = ~HCLK;

    // --------------------------------------------------------
    // INTERFACE + DUT  (single instance shared by all tests)
    // --------------------------------------------------------
    AHBInterface BUS (.HCLK(HCLK), .HRESETn(HRESETn));

    AHBSlaveTop DUT (
        .SlaveInterface      (BUS),
        .wait_slave_to_master(wait_ctrl)
    );

    // --------------------------------------------------------
    // VCD DUMP
    // --------------------------------------------------------
    initial begin
        $dumpfile("unified_7scenarios.vcd");
        $dumpvars(0, tb);
    end

    // --------------------------------------------------------
    // TASK : vi_check
    //   Self-checking pass/fail printer.
    // --------------------------------------------------------
    task automatic vi_check(
        input string  label,
        input logic   cond,
        input string  pass_msg,
        input string  fail_msg
    );
        if (cond) begin
            $display("  [PASS] %-40s %s", label, pass_msg);
            pass_count++;
        end else begin
            $display("  [FAIL] %-40s %s", label, fail_msg);
            fail_count++;
        end
    endtask

    // --------------------------------------------------------
    // TASK : do_reset
    //   Hard reset — drives every bus signal, holds 5 cycles,
    //   2-cycle post-reset settle.
    // --------------------------------------------------------
    task automatic do_reset();
        HRESETn      = 1'b0;
        BUS.HADDR    = 32'h0;
        BUS.HWRITE   = 1'b0;
        BUS.HTRANS   = IDLE;
        BUS.HWDATA   = 32'h0;
        BUS.HSIZE    = 3'b010;
        BUS.HBURST   = 3'b000;
        wait_ctrl    = 1'b0;
        repeat(5) @(posedge HCLK);
        HRESETn = 1'b1;
        repeat(2) @(posedge HCLK);
    endtask

    // --------------------------------------------------------
    // TASK : settle
    //   3-cycle gap so slave always_ff commits MemoryArray write
    //   into registered HRDATA before the next read samples it.
    // --------------------------------------------------------
    task automatic settle();
        repeat(3) @(posedge HCLK);
    endtask

    // --------------------------------------------------------
    // SHARED SIGNALS
    // --------------------------------------------------------
    logic [31:0] rdata, rdata1, rdata2;

    // ========================================================
    // MAIN TEST SEQUENCE
    // ========================================================
    initial begin

        pass_count = 0;
        fail_count = 0;

        $display("==========================================================");
        $display("  AHB-LITE UNIFIED TESTBENCH — 7 SCENARIOS");
        $display("==========================================================");

        // ======================================================
        // T1 — BACK-TO-BACK READ
        //   Pre-load 0x10 and 0x14, then issue NON_SEQ→SEQ with
        //   no IDLE between them.  HRDATA sampled when HREADY=1.
        // ======================================================
        $display("\n===== T1  BACK-TO-BACK READ =====");
        do_reset();

        // Pre-load both locations (settle between each)
        BUS.write(32'h10, 32'h1111_1111);
        settle();
        BUS.write(32'h14, 32'h2222_2222);
        settle();

        // Address phase — NON_SEQ on 0x10
        @(posedge HCLK);
        BUS.HADDR  <= 32'h10;
        BUS.HWRITE <= 1'b0;
        BUS.HTRANS <= NON_SEQ;
        BUS.HSIZE  <= 3'b010;

        // Pipeline — SEQ on 0x14 (no IDLE)
        @(posedge HCLK);
        BUS.HADDR  <= 32'h14;
        BUS.HTRANS <= SEQ;

        // FIX-F: wait for HREADY before sampling rdata1
        @(posedge HCLK);
        while (!BUS.HREADY) @(posedge HCLK);
        rdata1 = BUS.HRDATA;

        // FIX-F: wait for HREADY before sampling rdata2
        @(posedge HCLK);
        while (!BUS.HREADY) @(posedge HCLK);
        rdata2 = BUS.HRDATA;

        BUS.HTRANS <= IDLE;
        BUS.HWRITE <= 1'b0;

        $display("  rdata1 = %h  rdata2 = %h", rdata1, rdata2);

        vi_check("T1_rdata1_0x10",
                 rdata1 == 32'h1111_1111,
                 "rdata1=0x11111111 PASS",
                 $sformatf("rdata1=0x%08h expected 0x11111111 FAIL", rdata1));

        vi_check("T1_rdata2_0x14",
                 rdata2 == 32'h2222_2222,
                 "rdata2=0x22222222 PASS",
                 $sformatf("rdata2=0x%08h expected 0x22222222 FAIL", rdata2));

        vi_check("T1_no_error",
                 BUS.HRESP == 1'b0,
                 "HRESP=0 PASS",
                 "HRESP=1 unexpected FAIL");

        settle();

        // ======================================================
        // T2 — BACK-TO-BACK WRITE
        //   NON_SEQ→SEQ write, then read-back to verify both
        //   addresses were written correctly.
        // ======================================================
        $display("\n===== T2  BACK-TO-BACK WRITE =====");
        do_reset();

        @(posedge HCLK);
        BUS.HADDR  <= 32'h10;
        BUS.HWRITE <= 1'b1;
        BUS.HTRANS <= NON_SEQ;
        BUS.HSIZE  <= 3'b010;

        @(posedge HCLK);
        BUS.HADDR  <= 32'h14;
        BUS.HTRANS <= SEQ;
        BUS.HWDATA <= 32'hAAAA_AAAA;   // data phase for 0x10

        @(posedge HCLK);
        BUS.HWDATA <= 32'hBBBB_BBBB;   // data phase for 0x14

        @(posedge HCLK);
        BUS.HTRANS <= IDLE;
        BUS.HWRITE <= 1'b0;

        settle();   // FIX-E: let both MemoryArray writes commit

        BUS.read(32'h10, rdata1);
        settle();
        BUS.read(32'h14, rdata2);
        settle();

        $display("  Addr 0x10 = %h  Addr 0x14 = %h", rdata1, rdata2);

        vi_check("T2_write_0x10",
                 rdata1 == 32'hAAAA_AAAA,
                 "0x10=0xAAAAAAAA PASS",
                 $sformatf("0x10=0x%08h expected 0xAAAAAAAA FAIL", rdata1));

        vi_check("T2_write_0x14",
                 rdata2 == 32'hBBBB_BBBB,
                 "0x14=0xBBBBBBBB PASS",
                 $sformatf("0x14=0x%08h expected 0xBBBBBBBB FAIL", rdata2));

        vi_check("T2_no_error",
                 BUS.HRESP == 1'b0,
                 "HRESP=0 PASS",
                 "HRESP=1 unexpected FAIL");

        settle();

        // ======================================================
        // T3 — DATA INTEGRITY  (single write → read → verify)
        // ======================================================
        $display("\n===== T3  DATA INTEGRITY =====");
        do_reset();

        BUS.write(32'h00000010, 32'hDEAD_BEEF);
        settle();   // FIX-E
        BUS.read (32'h00000010, rdata);
        settle();

        $display("  Read Data = %h", rdata);

        vi_check("T3_data_integrity",
                 rdata === 32'hDEAD_BEEF,
                 "rdata=0xDEADBEEF PASS",
                 $sformatf("rdata=0x%08h expected 0xDEADBEEF FAIL", rdata));

        vi_check("T3_no_error",
                 BUS.HRESP == 1'b0,
                 "HRESP=0 PASS",
                 "HRESP=1 unexpected FAIL");

        settle();

        // ======================================================
        // T4 — NO SLAVE SELECTED (out-of-range → default error)
        //   OOR addresses >= 0x800 hit the always_comb mux in
        //   AHBSlaveTop which drives HRESP=1 combinationally.
        //   FIX-G: HRESP is checked ONE cycle BEFORE HTRANS goes
        //   back to IDLE so the OOR address is still on the bus.
        //   FIX-H: recovery uses unique address 0x50.
        // ======================================================
        $display("\n===== T4  NO SLAVE SELECTED (OOR) =====");
        do_reset();

        // Sub-test A: OOR READ at 0x800
        @(posedge HCLK);
        BUS.HADDR  <= 32'h0000_0800;
        BUS.HWRITE <= 1'b0;
        BUS.HTRANS <= NON_SEQ;
        BUS.HSIZE  <= 3'b010;

        // FIX-G: sample HRESP here, while OOR address still on bus
        @(posedge HCLK);
        vi_check("T4_OOR_read_HRESP",
                 BUS.HRESP == 1'b1,
                 "OOR READ HRESP=1 PASS",
                 "OOR READ HRESP not 1 FAIL");

        // Now return to IDLE
        BUS.HTRANS <= IDLE;

        @(posedge HCLK);
        vi_check("T4_OOR_read_HREADY",
                 BUS.HREADY == 1'b1,
                 "OOR READ HREADY=1 PASS",
                 "OOR READ HREADY not 1 FAIL");

        $display("  OOR READ  HRESP=%0b HREADY=%0b HRDATA=%h",
                 BUS.HRESP, BUS.HREADY, BUS.HRDATA);

        settle();

        // Sub-test B: OOR WRITE at 0x1000
        @(posedge HCLK);
        BUS.HADDR  <= 32'h0000_1000;
        BUS.HWRITE <= 1'b1;
        BUS.HTRANS <= NON_SEQ;
        BUS.HWDATA <= 32'hAAAA_BBBB;

        // FIX-G: sample HRESP before returning HTRANS to IDLE
        @(posedge HCLK);
        vi_check("T4_OOR_write_HRESP",
                 BUS.HRESP == 1'b1,
                 "OOR WRITE HRESP=1 PASS",
                 "OOR WRITE HRESP not 1 FAIL");

        BUS.HTRANS <= IDLE;
        BUS.HWRITE <= 1'b0;

        @(posedge HCLK);
        vi_check("T4_OOR_write_HREADY",
                 BUS.HREADY == 1'b1,
                 "OOR WRITE HREADY=1 PASS",
                 "OOR WRITE HREADY not 1 FAIL");

        $display("  OOR WRITE HRESP=%0b HREADY=%0b",
                 BUS.HRESP, BUS.HREADY);

        settle();

        // Sub-test C: recovery at unique address 0x50 (FIX-H)
        $display("  Checking recovery...");
        BUS.write(32'h0000_0050, 32'h1234_5678);
        settle();   // FIX-E
        BUS.read (32'h0000_0050, rdata);
        settle();

        vi_check("T4_recovery",
                 rdata === 32'h1234_5678,
                 "Recovery rdata=0x12345678 PASS",
                 $sformatf("Recovery rdata=0x%08h expected 0x12345678 FAIL", rdata));

        $display("  Read back = %h", rdata);
        settle();

        // ======================================================
        // T5 — SLAVE 1 ACCESS  (address 0x400–0x7FF)
        //   Decoder bit HADDR[10]=1 → HSEL[1].
        // ======================================================
        $display("\n===== T5  SLAVE 1 ACCESS =====");
        do_reset();

        BUS.write(32'h0000_0400, 32'hABCD_1234);
        settle();   // FIX-E
        BUS.read (32'h0000_0400, rdata);
        settle();

        $display("  Read Data = %h", rdata);

        vi_check("T5_slave1_data",
                 rdata === 32'hABCD_1234,
                 "Slave1 rdata=0xABCD1234 PASS",
                 $sformatf("Slave1 rdata=0x%08h expected 0xABCD1234 FAIL", rdata));

        vi_check("T5_no_error",
                 BUS.HRESP == 1'b0,
                 "HRESP=0 PASS",
                 "HRESP=1 unexpected FAIL");

        settle();

        // ======================================================
        // T6 — SLAVE 0 ACCESS + ISOLATION
        //   Decoder bit HADDR[10]=0 → HSEL[0].
        //   Also reads Slave 1 address to confirm no cross-talk.
        // ======================================================
        $display("\n===== T6  SLAVE 0 ACCESS + ISOLATION =====");
        do_reset();

        BUS.write(32'h0000_0010, 32'h1234_ABCD);
        settle();   // FIX-E
        BUS.read (32'h0000_0010, rdata);
        settle();

        $display("  Slave0 Read = %h", rdata);

        vi_check("T6_slave0_data",
                 rdata === 32'h1234_ABCD,
                 "Slave0 rdata=0x1234ABCD PASS",
                 $sformatf("Slave0 rdata=0x%08h expected 0x1234ABCD FAIL", rdata));

        // Isolation: Slave 1 at 0x410 must not contain Slave 0 data
        BUS.read(32'h0000_0410, rdata);
        settle();

        vi_check("T6_slave_isolation",
                 rdata !== 32'h1234_ABCD,
                 "Slave1 not polluted PASS",
                 "Slave1 returned Slave0 data — cross-talk FAIL");

        vi_check("T6_no_error",
                 BUS.HRESP == 1'b0,
                 "HRESP=0 PASS",
                 "HRESP=1 unexpected FAIL");

        settle();

        // ======================================================
        // T7 — ERROR INJECTION
        //   Step A: normal baseline write/read at 0x10.
        //   Step B: write to READ-ONLY address 0x02 → HRESP=1.
        //           FIX-I: address 0x02 is in RO range 0x00–0x03
        //           so slave fires HRESP=1 natively, no ERROR_INJECT
        //           macro needed.
        //   Step C: read back 0x02 → must NOT equal 0xDEADBEEF.
        //   Step D: HREADY must recover to 1 after error.
        // ======================================================
        $display("\n===== T7  ERROR INJECTION =====");
        do_reset();

        // Step A: baseline
        BUS.write(32'h10, 32'hAAAA_BBBB);
        settle();
        BUS.read (32'h10, rdata);
        settle();
        $display("  Before inject: HRDATA = %h", rdata);

        vi_check("T7_baseline_write",
                 rdata === 32'hAAAA_BBBB,
                 "Baseline rdata=0xAAAABBBB PASS",
                 $sformatf("Baseline rdata=0x%08h FAIL", rdata));

        // Step B: attempt write to read-only address 0x02
        //   Address phase
        @(posedge HCLK);
        BUS.HADDR  <= 32'h0000_0002;
        BUS.HWRITE <= 1'b1;
        BUS.HTRANS <= NON_SEQ;
        BUS.HSIZE  <= 3'b010;

        //   FIX-G: sample HRESP while OOR/RO address still active
        //   Data phase (HWDATA presented; slave ignores because RO)
        @(posedge HCLK);
        BUS.HWDATA <= 32'hDEAD_BEEF;
        BUS.HTRANS <= IDLE;
        BUS.HWRITE <= 1'b0;

        @(posedge HCLK);   // slave always_ff fires HRESP here

        vi_check("T7_RO_HRESP",
                 BUS.HRESP == 1'b1,
                 "RO write HRESP=1 PASS",
                 "RO write HRESP not asserted FAIL");

        $display("  RO write: HRESP=%0b HREADY=%0b", BUS.HRESP, BUS.HREADY);

        settle();

        // Step C: read back 0x02 — write must have been rejected
        @(posedge HCLK);
        BUS.HADDR  <= 32'h0000_0002;
        BUS.HWRITE <= 1'b0;
        BUS.HTRANS <= NON_SEQ;

        @(posedge HCLK);
        BUS.HTRANS <= IDLE;
        while (!BUS.HREADY) @(posedge HCLK);
        rdata = BUS.HRDATA;

        vi_check("T7_RO_write_rejected",
                 rdata !== 32'hDEAD_BEEF,
                 "Write rejected HRDATA!=0xDEADBEEF PASS",
                 $sformatf("Write NOT rejected rdata=0x%08h FAIL", rdata));

        $display("  After inject: HRDATA = %h (must not be 0xDEADBEEF)", rdata);

        // Step D: protocol recovery
        repeat(2) @(posedge HCLK);
        vi_check("T7_protocol_recovery",
                 BUS.HREADY == 1'b1,
                 "HREADY recovered to 1 PASS",
                 "HREADY stuck at 0 after error FAIL");

        settle();

        // ======================================================
        // FINAL REPORT
        // ======================================================
        $display("");
        $display("==========================================================");
        $display("  FINAL REPORT");
        $display("==========================================================");
        $display("  Scenarios : 7");
        $display("  PASS      : %0d", pass_count);
        $display("  FAIL      : %0d", fail_count);
        $display("==========================================================");
        if (fail_count == 0)
            $display("  RESULT : ALL CHECKS PASSED");
        else
            $display("  RESULT : %0d FAILURE(S) — search log for [FAIL]", fail_count);
        $display("==========================================================");

        #20;
        $finish;
    end

    // --------------------------------------------------------
    // WATCHDOG
    // --------------------------------------------------------
    initial begin
        #500_000;
        $display("[WATCHDOG] Timeout at 500 us");
        $finish;
    end

endmodule


